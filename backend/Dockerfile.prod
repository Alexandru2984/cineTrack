FROM rust:1.96-slim-bookworm@sha256:e18a79fc84dfcfc3ab5ba72290398a644c135c97eaa881447fddc354ee4701a3 AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
# Cargo.toml declares the benches target explicitly, so its source has to exist
# for the manifest to parse — even in this dependency-caching layer, which
# otherwise only needs a stub main.
RUN mkdir -p src benches \
  && echo "fn main() {}" > src/main.rs \
  && echo "fn main() {}" > benches/hot_paths.rs \
  && cargo build --release --locked \
  && rm -rf src benches
COPY . .
RUN touch src/main.rs && cargo build --release --locked

FROM gcr.io/distroless/cc-debian12:nonroot@sha256:66aa873a4a14fb164aa01296058efd8253744606d72715e45acface073359faa
COPY --from=builder --chown=nonroot:nonroot /app/target/release/cinetrack /usr/local/bin/cinetrack
USER nonroot:nonroot
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD ["/usr/local/bin/cinetrack", "--healthcheck"]
CMD ["cinetrack"]
