FROM rust:1.96-slim-bookworm@sha256:e18a79fc84dfcfc3ab5ba72290398a644c135c97eaa881447fddc354ee4701a3

RUN groupadd --gid 10001 app && \
    useradd --uid 10001 --gid app --create-home --shell /usr/sbin/nologin app && \
    mkdir -p /app/target /usr/local/cargo/registry /usr/local/cargo/git && \
    chown -R app:app /app /usr/local/cargo

WORKDIR /app
COPY --chown=app:app . .

USER app:app
HEALTHCHECK --interval=30s --timeout=3s --start-period=120s --retries=5 \
    CMD ["/app/target/debug/cinetrack", "--healthcheck"]
CMD ["cargo", "run", "--locked"]
