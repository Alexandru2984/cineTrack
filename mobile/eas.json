{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vazute.micutu.com",
        "EXPO_PUBLIC_USE_R2_IMAGES": "true",
        "EXPO_UPDATES_ENABLED": "false"
      }
    },
    "preview": {
      "autoIncrement": true,
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vazute.micutu.com",
        "EXPO_PUBLIC_USE_R2_IMAGES": "true",
        "EXPO_UPDATES_ENABLED": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vazute.micutu.com",
        "EXPO_PUBLIC_USE_R2_IMAGES": "true",
        "EXPO_UPDATES_ENABLED": "false"
      }
    }
  }
}
