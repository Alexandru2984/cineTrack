# CineTrack environment template.
#
# Copy to `.env` for the local dev stack (docker-compose.yml) and to `.env.prod`
# for production (docker-compose.prod.yml). Never commit the filled-in files —
# `.env` and `.env.prod` are gitignored. Generate strong secrets, e.g.:
#   JWT_SECRET:        openssl rand -base64 64
#   POSTGRES_PASSWORD: openssl rand -base64 24
# Production runtime DB credentials are generated by scripts/provision_db_role.sh.

# --- Application ---
APP_ENV=development            # `production` flips Secure cookies, disables reset-URL logging
APP_HOST=0.0.0.0
APP_PORT=8080
FRONTEND_URL=http://localhost:5173   # used to build password-reset links
RUST_LOG=cinetrack=info,actix_web=info

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=cinetrack
POSTGRES_USER=cinetrack_user
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://cinetrack_user:change-me-strong-password@db:5432/cinetrack

# Production only: DML-only backend role plus a separate schema owner used by
# the one-shot migration/catalog jobs. Do not reuse POSTGRES_PASSWORD.
# The provisioning script writes these safely.
APP_DATABASE_USER=cinetrack_app
APP_DATABASE_PASSWORD=generated-url-safe-password
APP_DATABASE_URL=
MIGRATION_DATABASE_USER=cinetrack_migrator
MIGRATION_DATABASE_PASSWORD=generated-url-safe-password
MIGRATION_DATABASE_URL=

# --- Auth / JWT ---
JWT_SECRET=change-me-must-be-at-least-32-bytes-long-random-string
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# --- TMDB ---
# Prefer the v4 Read Access Token (sent as a Bearer header, never in the URL).
# If only the v3 key is set, the client falls back to the `api_key` query param.
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=your-tmdb-v3-api-key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_TIMEOUT_SECONDS=10
# Conservative daily detail hydration: 4 requests/second, at most 200 items.
CATALOG_HYDRATION_DAILY_BUDGET=200
CATALOG_HYDRATION_DELAY_MS=250
# Focused refresh for distinct tracked titles; safe to run every six hours.
RELEASE_SCHEDULE_SYNC_BUDGET=200
RELEASE_SCHEDULE_SYNC_DELAY_MS=250

# --- CORS / rate limiting ---
CORS_ALLOWED_ORIGINS=http://localhost:5173   # comma-separated for multiple origins
RATE_LIMIT_REQUESTS_PER_SECOND=10
RATE_LIMIT_BURST_SIZE=50

# --- SMTP (optional) ---
# When unset, password-reset emails are logged instead of sent (dev only).
SMTP_HOST=
SMTP_PORT=587                  # 465 = implicit TLS, anything else = STARTTLS
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=CineTrack <noreply@localhost>
SMTP_TIMEOUT_SECONDS=15          # Bound each SMTP transaction to 1-60 seconds

# --- Expo Push Service (optional until push is enabled) ---
# Enable enhanced push security in EAS, then place its access token here.
EXPO_PUSH_ACCESS_TOKEN=
EXPO_PUSH_TIMEOUT_SECONDS=15

# --- Frontend build ---
VITE_API_URL=http://localhost:8080   # baked into the frontend bundle at build time
VITE_USE_R2_IMAGES=false            # enable only when R2 and its poster lifecycle are configured

# --- Cloudflare R2 (optional) ---
# S3-compatible object storage for avatars, poster cache and database backups.
R2_S3_API=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cinetrack
R2_PUBLIC_BASE_URL=                 # optional public bucket domain
