FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66
WORKDIR /app
RUN npm install --global npm@12.0.1 && chown node:node /app

USER node
COPY --chown=node:node package*.json ./
RUN npm ci
COPY --chown=node:node . .

HEALTHCHECK --interval=30s --timeout=3s --start-period=15s --retries=5 \
    CMD ["wget", "-q", "-O", "/dev/null", "http://127.0.0.1:5173/"]
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
