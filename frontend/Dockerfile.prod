FROM node:26-alpine@sha256:e88a35be04478413b7c71c455cd9865de9b9360e1f43456be5951032d7ac1a66 AS builder
WORKDIR /app
RUN npm install --global npm@12.0.1 --no-audit --no-fund
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_URL=""
ARG VITE_USE_R2_IMAGES="false"
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_USE_R2_IMAGES=$VITE_USE_R2_IMAGES
RUN npm run build

FROM nginx:1.31-alpine@sha256:7068961d45b07b2af510ac002e9daa63a1d3eba2111202d6768798690800fffd
RUN apk info --exists 'c-ares=1.34.8-r0' && \
    apk info --exists 'libexpat=2.8.2-r0' && \
    apk info --exists 'curl=8.21.0-r0' && \
    apk info --exists 'libcurl=8.21.0-r0'
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx-main.conf /etc/nginx/nginx.conf
COPY nginx-spa.conf /etc/nginx/conf.d/default.conf

# Run as non-root: nginx:alpine has an 'nginx' user (uid 101)
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    touch /var/run/nginx.pid && chown nginx:nginx /var/run/nginx.pid

USER nginx
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD ["wget", "-q", "-O", "/dev/null", "http://127.0.0.1:8080/"]
ENTRYPOINT []
CMD ["nginx", "-g", "daemon off;"]
